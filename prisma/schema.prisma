// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Project {
  id          String     @id @default(cuid())
  name        String
  description String     @default("")
  techStack   String     @default("")
  isLocked    Boolean    @default(false) // Admin toggle: when true, hidden from employees
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  files       CodeFile[]
  conversations Conversation[]
  lock        ProjectLock?
}

model ProjectLock {
  id        String   @id @default(cuid())
  projectId String   @unique
  lockedBy  String   // Employee name or "admin"
  lockedAt  DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model DeleteRequest {
  id          String   @id @default(cuid())
  type        String   // "project", "conversation", "directChat", "file"
  targetId    String   // ID of the item to delete
  targetName  String   // Name/display info for admin review
  requestedBy String   // Employee name
  reason      String   @default("")
  status      String   @default("pending") // pending, approved, rejected
  reviewedBy  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Admin {
  id         String   @id @default(cuid())
  email      String   @unique
  password   String   // bcrypt hashed
  smtpHost   String   @default("")
  smtpPort   String   @default("587")
  smtpUser   String   @default("")
  smtpPass   String   @default("")
  smtpFrom   String   @default("")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Employee {
  id           String   @id @default(cuid())
  employeeId   String   @unique // Unique login ID (e.g., "EMP001")
  name         String
  password     String   // bcrypt hashed
  createdBy    String   @default("admin")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  assignments  TrainingAssignment[]
}

model CodeFile {
  id        String   @id @default(cuid())
  projectId String
  fileName  String
  filePath  String
  language  String   @default("typescript")
  content   String
  version   Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, filePath])
}

model Conversation {
  id        String     @id @default(cuid())
  projectId String?
  title     String     @default("New Chat")
  mode      String     @default("project") // "direct", "project", "business"
  isHidden  Boolean    @default(false) // Admin can hide chats
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  project   Project?   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  messages  Message[]
  lock      ConversationLock?
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  role           String       @default("user")
  content        String
  attachments    String       @default("[]") // JSON array of {type, url, name, mimeType}
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model Training {
  id          String   @id @default(cuid())
  title       String
  category    String
  difficulty  String   @default("beginner") // beginner, intermediate, advanced
  videoUrl    String   @default("") // YouTube embed URL
  description String   @default("")
  questions   String   @default("[]") // JSON array of quiz questions
  createdBy   String   @default("admin")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  assignments TrainingAssignment[]
}

model TrainingAssignment {
  id              String    @id @default(cuid())
  trainingId      String
  employeeId      String
  status          String    @default("due") // due, in_progress, finished
  score           Int?
  answers         String    @default("{}") // JSON object of answers
  attempts        Int       @default(0)
  maxAttempts     Int       @default(1)
  retakeRequested Boolean   @default(false)
  retakeApproved  Boolean   @default(false)
  dueDate         DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  training        Training  @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  employee        Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([trainingId, employeeId])
}

model AuditLog {
  id          String   @id @default(cuid())
  action      String   // "rename", "lock", "unlock", "hide", "unhide", "access", "delete", "assign_training", "reset_password"
  targetType  String   // "project", "conversation", "direct_chat", "business_chat", "employee", "training"
  targetId    String
  targetName  String   @default("")
  oldValue    String   @default("") // previous name/value
  newValue    String   @default("") // new name/value
  performedBy String   @default("admin") // who did it
  createdAt   DateTime @default(now())
}

model ConversationLock {
  id             String       @id @default(cuid())
  conversationId String       @unique
  lockedBy       String
  lockedAt       DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}
