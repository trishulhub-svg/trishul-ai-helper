// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id          String     @id @default(cuid())
  name        String
  description String     @default("")
  techStack   String     @default("")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  files       CodeFile[]
  conversations Conversation[]
  lock        ProjectLock?
}

model ProjectLock {
  id        String   @id @default(cuid())
  projectId String   @unique
  lockedBy  String   // Employee name
  lockedAt  DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model DeleteRequest {
  id          String   @id @default(cuid())
  type        String   // "project", "conversation", "directChat", "file"
  targetId    String   // ID of the item to delete
  targetName  String   // Name/display info for admin review
  requestedBy String   // Employee name
  reason      String   @default("")
  status      String   @default("pending") // pending, approved, rejected
  reviewedBy  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   // bcrypt hashed
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CodeFile {
  id        String   @id @default(cuid())
  projectId String
  fileName  String
  filePath  String
  language  String   @default("typescript")
  content   String
  version   Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, filePath])
}

model Conversation {
  id        String     @id @default(cuid())
  projectId String?
  title     String     @default("New Chat")
  mode      String     @default("project") // "direct" or "project"
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  project   Project?   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  messages  Message[]
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  role           String       @default("user")
  content        String
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}
